# All optional. Defaults work for local dev with Supabase + bot running.

VITE_SERVER_URL=              # Supabase functions URL (default: http://127.0.0.1:54321/functions/v1)
VITE_PIPECAT_TRANSPORT=       # WebRTC transport: smallwebrtc | daily (default: smallwebrtc)
VITE_BOT_URL=                 # Bot start URL for SmallWebRTC / Ladle (default: http://localhost:7860)
VITE_MAINTENANCE_MODE=        # Set to 1 to show maintenance screen
VITE_SERVER_LEADERBOARD_ENDPOINT=  # Leaderboard endpoint path (default: /leaderboard_resources)
