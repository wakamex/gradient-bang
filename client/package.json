{
  "name": "@gradient-bang/workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "description": "Gradient Bang Web Client Workspace",
  "author": {
    "name": "Jon Taylor",
    "url": "https://github.com/jptaylor"
  },
  "scripts": {
    "prepare": "cd .. && husky client/.husky",
    "dev": "turbo run dev --filter=@gradient-bang/app",
    "dev:all": "turbo run dev stories",
    "dev:stories": "turbo run stories --filter=@gradient-bang/app",
    "dev:starfield": "turbo run dev:preview --filter=@gradient-bang/starfield",
    "build": "turbo run build",
    "build:app": "turbo run build --filter=@gradient-bang/app",
    "build:starfield": "turbo run build --filter=@gradient-bang/starfield",
    "preview": "turbo run preview",
    "lint": "turbo run lint",
    "bump:patch": "cd app && pnpm version patch --no-git-tag-version && cd ../starfield && pnpm version patch --no-git-tag-version && cd .. && pnpm build",
    "bump:minor": "cd app && pnpm version minor --no-git-tag-version && cd ../starfield && pnpm version minor --no-git-tag-version && cd .. && pnpm build",
    "bump:major": "cd app && pnpm version major --no-git-tag-version && cd ../starfield && pnpm version major --no-git-tag-version && cd .. && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "prettier": "^3.8.1",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  },
  "lint-staged": {
    "app/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "starfield/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}